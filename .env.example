# === Database (Postgres, e.g. Supabase) ===
# Pooled connection used by the app at runtime (port 6543 with ?pgbouncer=true).
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"
# Direct connection used by Prisma migrations and `pnpm build` on Vercel (port 5432).
DIRECT_URL="postgresql://user:password@host:5432/postgres"

# === Supabase Auth ===
# Project URL and anon (public) key from Supabase Dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Service role key — server-only. Required on Vercel for image uploads (Supabase Storage).
# Never expose in client code or NEXT_PUBLIC_* variables.
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Public bucket for menu item images (create in Supabase → Storage, set to public).
SUPABASE_STORAGE_BUCKET="menu-items"

# Google OAuth and Email/Password are enabled in Supabase Dashboard → Authentication → Providers.
# For Google, use the same OAuth client from Google Cloud Console and add this redirect URI:
#   https://your-project-ref.supabase.co/auth/v1/callback

# === Admin access ===
# Comma-separated allowlist of emails permitted to access /dashboard.
ALLOWED_EMAILS="owner@example.com"

# === Dev bypass (local testing only — ignored in production) ===
AUTH_DEV_BYPASS="true"
AUTH_DEV_BYPASS_EMAIL="dev@test.local"
AUTH_DEV_BYPASS_PASSWORD="dev123456"

# === App ===
# Local: http://localhost:3000
# Production (Vercel): https://your-app.vercel.app
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# --- Vercel deploy checklist ---
# 1. Add all variables above in Vercel → Project → Settings → Environment Variables.
# 2. Supabase Auth → URL Configuration:
#    - Site URL: NEXT_PUBLIC_BASE_URL (production domain)
#    - Redirect URLs: https://your-app.vercel.app/auth/callback
# 3. Supabase Storage: create bucket `menu-items` (public read).
# 4. After first deploy, seed the menu if needed: `pnpm db:seed` (run locally with prod DATABASE_URL).
