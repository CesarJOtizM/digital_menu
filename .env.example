# === Database (Postgres, e.g. Supabase) ===
# Pooled connection used by the app at runtime (port 6543 with ?pgbouncer=true).
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"
# Direct connection for Prisma migrate deploy (port 5432, NOT the 6543 pooler).
# Supabase: Project Settings → Database → Connection string → URI → "Direct connection"
#   host must be db.<project-ref>.supabase.co (not the pooler host).
# If the password contains @ # % or other special chars, URL-encode them (@ → %40).
DIRECT_URL="postgresql://postgres:password@db.your-project-ref.supabase.co:5432/postgres"

# === Supabase Auth ===
# Project URL and publishable key from Supabase Dashboard → Project Settings → API Keys.
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_your-key"

# Secret key — server-only. Required on Vercel for image uploads (Supabase Storage).
# Never expose in client code or NEXT_PUBLIC_* variables.
SUPABASE_SECRET_KEY="sb_secret_your-key"

# Public bucket for menu item images (create in Supabase → Storage, set to public).
SUPABASE_STORAGE_BUCKET="menu-items"


# === Dev bypass (local testing only — ignored in production) ===
AUTH_DEV_BYPASS="true"
AUTH_DEV_BYPASS_EMAIL="dev@test.local"
AUTH_DEV_BYPASS_PASSWORD="dev123456"

# === App ===
# Local: http://localhost:3000
# Production (Vercel): https://your-app.vercel.app
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# --- Vercel deploy checklist ---
# 1. Add all variables above in Vercel → Project → Settings → Environment Variables.
# 2. Supabase Auth → URL Configuration:
#    - Site URL: NEXT_PUBLIC_BASE_URL (production domain)
#    - Redirect URLs: https://your-app.vercel.app/auth/callback
# 3. Supabase Storage: create bucket `menu-items` (public read).
# 4. After first deploy, seed the menu if needed: `pnpm db:seed` (run locally with prod DATABASE_URL).
#
# --- If build fails with Prisma P3009 (failed migration) ---
# A previous deploy left `0001_init_menu` marked as failed. From your machine with prod DIRECT_URL:
#   pnpm exec prisma migrate status
# In Supabase → SQL Editor, check whether Menu/Category/Item tables exist.
# If tables exist:  pnpm exec prisma migrate resolve --applied 0001_init_menu
# If tables missing: pnpm exec prisma migrate resolve --rolled-back 0001_init_menu
# Then:             pnpm exec prisma migrate deploy
# Redeploy on Vercel.
